# -----------------------
# GLOBAL WIDGET STYLES
# -----------------------
# Rounded button — use in place of Button for text buttons
<RoundedButton>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: (0.45, 0.48, 0.52, 1) if self.hovered and self.state == 'normal' else (0.35, 0.38, 0.42, 1) if self.state == 'normal' else (0.25, 0.28, 0.32, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]

# Rounded toggle button — use in place of ToggleButton for text toggle buttons
<RoundedToggleButton>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: (0.45, 0.48, 0.52, 1) if self.hovered and self.state == 'normal' else (0.35, 0.38, 0.42, 1) if self.state == 'normal' else (0.2, 0.55, 0.82, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]

# Fix checkbox visibility on macOS Metal backend (#466)
<CheckBox>:
    background_checkbox_normal: 'data/icons/checkbox_off.png'
    background_checkbox_down: 'data/icons/checkbox_on.png'
    background_radio_normal: 'data/icons/radio_off.png'
    background_radio_down: 'data/icons/radio_on.png'
    color: 1, 1, 1, 1

# Rounded style for file/folder chooser buttons (extend Button in Python)
<FileChooseBTN>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: (0.45, 0.48, 0.52, 1) if self.hovered and self.state == 'normal' else (0.35, 0.38, 0.42, 1) if self.state == 'normal' else (0.25, 0.28, 0.32, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]

<FileSaveBTN>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: (0.45, 0.48, 0.52, 1) if self.hovered and self.state == 'normal' else (0.35, 0.38, 0.42, 1) if self.state == 'normal' else (0.25, 0.28, 0.32, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]

<FolderChooseBTN>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: (0.45, 0.48, 0.52, 1) if self.hovered and self.state == 'normal' else (0.35, 0.38, 0.42, 1) if self.state == 'normal' else (0.25, 0.28, 0.32, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]

# Rounded Spinner (dropdown) — darker than buttons with a separator line
<Spinner>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: (0.22, 0.24, 0.28, 1) if self.state == 'normal' else (0.18, 0.20, 0.24, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]
        # Down arrow indicator on right edge
        Color:
            rgba: 0.6, 0.63, 0.67, 1
        Triangle:
            points: [self.right - dp(20), self.center_y + dp(3), self.right - dp(10), self.center_y + dp(3), self.right - dp(15), self.center_y - dp(3)]

# -----------------------
# MAIN DISPLAY
# -----------------------
<MainDisplay>:
    id: maindisplay_id

    # Primary Display of Camera Results
    ShaderViewer:
        id: viewer_id
        pos: 0, 0
        size_hint: None, None
        size: root.width, root.height
        auto_bring_to_front: False
        do_rotation: False
        do_translation: True

	MotionSettings:
        id: motionsettings_id
        size_hint: None, None
        size: self.settings_width, root.height
        pos: -self.settings_width+self.tab_width, 0

    ImageSettings:
        id: imagesettings_id
        size_hint: None, None
        size: self.settings_width, root.height
        pos: root.width-self.tab_width, 0


    # Camera Controls
    # ------------------------------
    BoxLayout:
        orientation: 'horizontal'
        padding: '5dp'
        spacing: '5dp'
        pos: (root.width - 9*dp(40))/2, 0

		Button:
			id: open_last_save_folder
			tooltip_text: 'Open Last Save Folder'
            border: 0, 0, 0, 0
            background_normal: './data/icons/photos.png'
            background_down: './data/icons/photos_down.png'
            size_hint: None, None
            size: '40dp', '40dp'
            on_release: root.open_save_folder_button()

        FolderChooseBTN:
            id: live_folder_btn
			tooltip_text: 'Set destination folder for image & video files'
            border: 0, 0, 0, 0
            background_color: 1, 1, 1, 1
            background_normal: './data/icons/folder.png' # Press to Select Folder
            background_down: './data/icons/folder_down.png'
            size_hint: None, None
            size: '40dp', '40dp'
            on_release: self.choose('live_folder')

        ToggleButton:
            id: live_btn
			tooltip_text: 'Freeze live image'
            border: 0, 0, 0, 0
            background_normal: './data/icons/pause.png' # Press to Pause Live Stream
            background_down: './data/icons/play.png' # Press to Play Live Stream
            size_hint: None, None
            size: '40dp', '40dp'
            state: 'normal'
            on_release: root.cam_toggle()

        Button:
            id: capture_btn
			tooltip_text: 'Snap live image'
            border: 0, 0, 0, 0
            background_normal: './data/icons/capture.png' # Press to Capture Image
            background_down: './data/icons/capture_down.png'
            size_hint: None, None
            size: '40dp', '40dp'
            on_release: root.live_capture()

        ToggleButton:
            id: composite_btn
			tooltip_text: 'Acquire composite fluorescence image for channels set to acquire\nincluding either bright field or phase contrast'
            border: 0, 0, 0, 0
            background_normal: './data/icons/composite.png' # Press to Capture Composite Image
            background_down: './data/icons/composite_down.png'
            size_hint: None, None
            size: '40dp', '40dp'
            on_release: root.composite_capture()

        ToggleButton:
            id: record_btn
			tooltip_text: 'Record live image stream as an mp4 video or as individual frames\n(30 seconds maximum record time)'
            border: 0, 0, 0, 0
            background_normal: './data/icons/record.png' # Press to Record Live Stream
            background_down: './data/icons/stop.png' # Press to Stop Recording
            size_hint: None, None
            size: '40dp', '40dp'
            on_press: root.record_button()

        Button:
            id: fit_btn
			tooltip_text: 'Fit live image to window'
            border: 0, 0, 0, 0
            background_normal: './data/icons/fit.png' # Press to Fit Image to Window
            background_down: './data/icons/fit_down.png'
            size_hint: None, None
            size: '40dp', '40dp'
            on_release: root.fit_image()

        Button:
            id: one2one_btn
			tooltip_text: 'Show live image as\n1 camera pixel to 1 screen pixel'
            border: 0, 0, 0, 0
            background_normal: './data/icons/one2one.png' # Press to Scale Image Pixels 1:1 with Screen
            background_down: './data/icons/one2one_down.png'
            size_hint: None, None
            size: '40dp', '40dp'
            on_release: root.one2one_image()



# ShaderViewer - Shaded Live Camera view
# ------------------------------------------
<ShaderViewer>:
    ScopeDisplay:
        id: scope_display_id
        size_hint: None, None
        size: root.width, root.height
		fit_mode: 'contain'
		on_touch_down: self.touch(args[0], args[1]) # 0 is Widget, 1 is MotionEvent
        canvas.before:
            Color:
                rgba: 0.15, 0.15, 0.15, 1
            Rectangle:
                pos: self.pos
                size: self.size

# ShaderEditor - view and edit shader code
# ------------------------------------------
<ShaderEditor>:
    orientation: 'horizontal'
    BoxLayout:
        orientation: 'vertical'
        # Fragment Shader Editor
        Label:
            text: 'Fragment Shader'
            size_hint_y: None
            height: self.texture_size[1] + 10
        CodeInput:
            text: root.fs
            lexer: GLShaderLexer()
            on_text: root.fs = args[1]

        # Vertex Shader Editor
        Label:
            text: 'Vertex Shader'
            size_hint_y: None
            height: self.texture_size[1] + 10
        CodeInput:
            text: root.vs
            lexer: GLShaderLexer()
            on_text: root.vs = args[1]
    ToggleButton:
        id: toggle_editor
        size_hint: None, None
        size: '30dp', '60dp'
        pos_hint: {"x":0, "y":0.5}
        border: 0, 0, 0, 0
        background_normal: './data/icons/right_arrow_right_arc.png'
        background_down: './data/icons/left_arrow_right_arc.png'
        on_press: root.toggle_editor()


<AccordionItemXyStageControl>:
	title: 'XY Stage Control'
	XYStageControl:
		id: xy_stagecontrol_id



# MotionSettings - view and control motion control Board
# ------------------------------------------
<MotionSettings>:
    orientation: 'horizontal'

	Accordion:
		orientation: 'vertical'
		id: motionsettings_accordion_id

        # MICROSCOPE SETTINGS
        AccordionItem:
            title: 'Microscope Settings'
            collapse: False
			on_collapse: root.accordion_collapse()
            MicroscopeSettings:
                id: microscope_settings_id

        # FOCUS SETTINGS
		AccordionItem:
			title: 'Objective Control'
			on_collapse: root.accordion_collapse()
			VerticalControl:
				id: verticalcontrol_id

        # PROTOCOL SETTINGS
		AccordionItem:
			title: 'Protocol'
			id: motionsettings_protocol_accordion_id
			on_collapse: root.accordion_collapse()
			ProtocolSettings:
                id: protocol_settings_id

		# POST PROCESSING
		AccordionItem:
			title: 'Post Processing'
			on_collapse: root.accordion_collapse()
			PostProcessingAccordion:
                id: post_processing_id

    RelativeLayout:
        size_hint: None, None
        width: dp(30)
        height: dp(120)
        pos_hint: {'center_y': 0.5}
        ToggleButton:
            id: toggle_motionsettings
            size_hint: 1, 1
            background_normal: ''
            background_down: ''
            background_color: 0, 0, 0, 0
            on_press: root.toggle_settings()
            Image:
                source: './data/icons/right_arrow_right_arc.png' if toggle_motionsettings.state == 'normal' else './data/icons/left_arrow_right_arc.png'
                size_hint: None, None
                size: dp(30), dp(60)
                center_y: toggle_motionsettings.center_y
                right: toggle_motionsettings.right

<VerticalControl>:
	orientation: 'vertical'
	padding: '5dp'
    spacing: '5dp'

    canvas:
        Color:
            rgba: 0.1, 0.1, 0.1, 0.7
		Rectangle:
			size: self.size
			pos: self.pos
	Label:
		text:'Adjust Focus'
		font_size: '16sp'
		size_hint_y: None
		height: '30dp'
		spacing: '5dp'
		color: [51/255, 181/255, 229/255, 1]

	BoxLayout:
		orientation: 'horizontal'
		size_hint_y: None
		height: '170dp'

		BoxLayout:
		    orientation: 'vertical'
		    size_hint_x: None
		    width: '40dp'
		    spacing: '5dp'

		    Label:
		    Button:
		        id: fast_up
				tooltip_text: 'Coarse Up'
				border: 0, 0, 0, 0
		        size_hint: None, None
		        size: '30dp', '40dp'
				background_normal: './data/icons/UU_normal.png'
				background_down: './data/icons/UU_down.png'
				on_release: root.coarse_up()
		    Button:
		        id: slow_up
				tooltip_text: 'Fine Up'
				border: 0, 0, 0, 0
		        size_hint: None, None
		        size: '30dp', '30dp'
				background_normal: './data/icons/U_normal.png'
				background_down: './data/icons/U_down.png'
				on_release: root.fine_up()
		    Button:
		        id: slow_down
				tooltip_text: 'Fine Down'
				border: 0, 0, 0, 0
		        size_hint: None, None
		        size: '30dp', '30dp'
				background_normal: './data/icons/D_normal.png'
				background_down: './data/icons/D_down.png'
				on_release: root.fine_down()
		    Button:
		        id: fast_down
				tooltip_text: 'Coarse Down'
				border: 0, 0, 0, 0
		        size_hint: None, None
		        size: '30dp', '40dp'
				background_normal: './data/icons/DD_normal.png'
				background_down: './data/icons/DD_down.png'
				on_release: root.coarse_down()
		    Label:

		BoxLayout:
			orientation: 'vertical'
			size_hint_x: None
			width: '40dp'
			Label:
				size_hint_y: None
				height: '15dp'
		    ModSlider:
		        id: obj_position
		        orientation: 'vertical'
		        min: 0.
		        max: 14000.
		        value: 0.
				step: 0.1
		        cursor_size: '30dp','40dp'
		        cursor_image: './data/icons/objective.png'
		        cursor_disabled_image: './data/icons/objective.png'
		        value_track: True
		        value_track_color: 51/255, 181/255, 229/255, 1
		        value_track_width: '5dp'
		        disabled: False
				on_release: root.set_position(self.value)
			Label:
				size_hint_y: None
				height: '15dp'

		BoxLayout:
		    orientation: 'vertical'
		    padding: '5dp'
			spacing: '5dp'

		    Label:
		        size_hint_y: None
		        height: '20dp'
				halign: 'center'
		        font_size: '12sp'
		        text: 'Z-Position (um)'

		    TextInput:
				id: z_position_id
            	multiline: False
		        size_hint_y: None
		        height: '30dp'
		        font_size: '12sp'
				halign: 'center'
            	input_filter: 'float'
		        text: ''
                on_text_validate: root.set_position(self.text)
				on_focus: if not self.focus: root.set_position(self.text)

			BoxLayout:
				orientation:'horizontal'
				padding: '0dp'
				spacing: '5dp'

				RoundedButton:
					id: home_id
					tooltip_text: 'Lower focus completely'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					text: 'Home'
					on_release: root.home()
				RoundedButton:
					text: 'Set Z'
					tooltip_text: 'Store Z-value\nfor current channel'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: root.set_bookmark()
				RoundedButton:
					text: 'Set All Z'
					tooltip_text: 'Store Z-value\nfor all channels'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: root.set_all_bookmarks()
			RoundedButton:
				text: 'Go to Set Z'
				tooltip_text: 'Go to stored Z-value'
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				on_release: root.goto_bookmark()

    		RoundedToggleButton:
    			id: autofocus_id
				tooltip_text: 'Autofocus live image, make sure objective is set correctly and the starting focus is within a reasonable range of the true focus'
    		    size_hint_y: None
    		    height: '30dp'
    			font_size: '12sp'
    			text: 'Autofocus'
    			on_release: root.run_autofocus_from_ui()

	Label:
		text:'Turret Selection'
		id: turret_selection_label
		font_size: '16sp'
		size_hint_y: None
		height: '30dp' if self.visible else 0
		opacity: 1 if self.visible else 0
		disabled: not self.visible
		spacing: '5dp'
		color: [51/255, 181/255, 229/255, 1]
		visible: True

	BoxLayout:
		orientation: 'horizontal'
		id: turret_btn_box
		size_hint_y: None
		height: '30dp' if self.visible else 0
		opacity: 1 if self.visible else 0
		disabled: not self.visible
		visible: True

		RoundedToggleButton:
			id: turret_pos_1_btn
			text: '1'
			tooltip_text: 'Select turret position 1'
			state: 'down'
            on_release: root.turret_select(1)
		RoundedToggleButton:
			id: turret_pos_2_btn
			text: '2'
			tooltip_text: 'Select turret position 2'
            on_release: root.turret_select(2)
		RoundedToggleButton:
			id: turret_pos_3_btn
			text: '3'
			tooltip_text: 'Select turret position 3'
            on_release: root.turret_select(3)
		RoundedToggleButton:
			id: turret_pos_4_btn
			text: '4'
			tooltip_text: 'Select turret position 4'
            on_release: root.turret_select(4)

	BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '30dp'
        Label:
            text: 'Objective'
            size_hint_x: None
            width: '120dp'
			font_size: '12sp'
	    Spinner:
			id: objective_spinner2
			sync_height: True
	        text: 'Select'
			font_size:'12sp'
			option_cls: "SpinnerOption0"
			text_autoupdate: True
	        on_release: root.load_objectives()
	        on_text: root.select_objective()

	RoundedButton:
		id: set_turret_objective_btn
		text: 'Set Turret Objective'
		size_hint_y: None
		height: '30dp'
		font_size: '12sp'
        on_release: root.set_turret_objective()

	RoundedButton:
		id: reset_turret_objective_btn
		text: 'Reset Turret Objective'
		size_hint_y: None
		height: '30dp'
		font_size: '12sp'
		on_release: root.reset_turret_objective()
            
	ZStack:
		id: zstack_id


# Z-Stack Settings
<ZStack>:
	BoxLayout:
		orientation: 'vertical'
		padding: '5dp'
	    spacing: '5dp'
		pos_hint: {'x': 0.0, 'y': 0.0}

		Label:
			text:'Acquire Z Stack'
			tooltip_text: 'Acquire and save Z-stack images'
			font_size: '16sp'
	        size_hint_y: None
	        height: '30dp'
			spacing: '5dp'
			color: [51/255, 181/255, 229/255, 1]
		BoxLayout:
		    orientation: 'horizontal'
		    size_hint_y: None
		    height: '30dp'
			spacing: '5dp'
			Label:
				font_size: '12sp'
				text: 'Step size (um)'
			Label:
				font_size: '12sp'
				text: 'Range'
			Label:
				font_size: '12sp'
				text: '# of Steps'
		BoxLayout:
		    orientation: 'horizontal'
		    size_hint_y: None
		    height: '30dp'
			spacing: '5dp'

			TextInput:
				id: zstack_stepsize_id
				tooltip_text: 'Z-stack slice spacing'
	        	multiline: False
		        size_hint_y: None
		        height: '30dp'
		        font_size: '12sp'
				halign: 'center'
	        	input_filter: 'float'
				text: '0'
	            on_text_validate: root.set_steps()
	            on_focus: if not self.focus: root.set_steps()

			TextInput:
				id: zstack_range_id
				tooltip_text: 'Total stack depth'
	        	multiline: False
		        size_hint_y: None
		        height: '30dp'
		        font_size: '12sp'
				halign: 'center'
	        	input_filter: 'float'
				text: '0'
	            on_text_validate: root.set_steps()
	            on_focus: if not self.focus: root.set_steps()

			TextInput:
				id: zstack_steps_id
				tooltip_text: 'Resulting number of slices in the stack'
	        	multiline: False
		        size_hint_y: None
		        height: '30dp'
		        font_size: '12sp'
				halign: 'center'
	        	input_filter: 'int'
				text: '0'
		        disabled: True

	    Spinner:
			id: zstack_spinner
			tooltip_text: 'Position to start Z-Stack'
			sync_height: True
			size_hint_y: None
			height: '30dp'
	        text: 'Z Stack'
			font_size: '12sp'
			option_cls: "SpinnerOption0"
			text_autoupdate: True
			values: ('Current Position at Top', 'Current Position at Center', 'Current Position at Bottom')
			on_text: root.set_position()
			# values: ('Focus at Top', 'Focus at Center', 'Focus at Bottom', 'Current Position at Top', 'Current Position at Center', 'Current Position at Bottom')

		RoundedToggleButton:
			id: zstack_aqr_btn
			size_hint_y: None
			height: '30dp'
			text: 'Acquire'
			tooltip_text: 'Acquire Z-stack'
			font_size: '12sp'
			on_release: root.run_zstack_acquire_from_ui()

		Label:

<XYStageControl>:
	orientation: 'vertical'
	padding: '5dp'
	spacing: '5dp'

    canvas:
        Color:
            rgba: 0.1, 0.1, 0.1, 0.7
        Rectangle:
            size: self.size
            pos: self.pos

	# HOME and CALIBRATE STAGE
	BoxLayout:
		orientation: 'horizontal'
		size_hint_y: None
		height: '30dp'
		spacing: '5dp'

		# HOME STAGE
		RoundedButton: 
			id: home_id
			tooltip_text: 'Home microscope to upper left corner (A1)'
			font_size: '12sp'
			text: 'Home Stage'
			on_release: root.home()
		# Button: 
		# 	id: center_id
		# 	font_size: '12sp'
		# 	text: 'Center Stage'
		# 	on_release: root.center()
		# Button:
		# 	text: 'Calibrate'
		# 	font_size: '12sp'
		# 	on_release: root.calibrate()

	# Two Columns for X and Y Directions
	BoxLayout:
		orientation: 'horizontal'
		spacing: '5dp'
		size_hint_y: None
		height: '170dp'

		# X Direction Controls
		BoxLayout:
			orientation: 'vertical'
			spacing: '5dp'
	
			Label:
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: 'X: (mm)'
				tooltip_text: 'Current X value'

			# Set and Display X Position	
			TextInput:
				id: x_pos_id
				multiline: False
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				halign: 'center'
				input_filter: 'float'
				text: ''
				on_text_validate: root.set_xposition(self.text)
				on_focus: if not self.focus: root.set_xposition(self.text)
			
			# Set X Bookmark
			RoundedButton:
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: 'Set X'
				tooltip_text: 'Save current X position'
				on_release: root.set_xbookmark()

			# Goto X Bookmark
			RoundedButton:
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: 'Go to X'
				tooltip_text: 'Return to saved X position'
				on_release: root.goto_xbookmark()

			# X-Dir Controls
			BoxLayout:
				orientation: 'horizontal'
				spacing: '5dp'
				size_hint_y: None
				height: '30dp'

				Button: # COARSE LEFT
					border: 0, 0, 0, 0
					size_hint: None, None
					tooltip_text: 'Coarse Left'
					size: '30dp', '30dp'
					background_normal: './data/icons/LL_normal.png'
					background_down: './data/icons/LL_down.png'
					on_release: root.coarse_left()

				Button: # FINE LEFT
					id: slow_up
					tooltip_text: 'Fine Left'
					border: 0, 0, 0, 0
					size_hint: None, None
					size: '25dp', '30dp'
					background_normal: './data/icons/L_normal.png'
					background_down: './data/icons/L_down.png'
					on_release: root.fine_left()

				Button: # FINE RIGHT
					id: slow_down
					tooltip_text: 'Fine Right'
					border: 0, 0, 0, 0
					size_hint: None, None
					size: '25dp', '30dp'
					background_normal: './data/icons/R_normal.png'
					background_down: './data/icons/R_down.png'
					on_release: root.fine_right()
			
				Button: # COARSE RIGHT
					id: fast_down
					tooltip_text: 'Coarse Right'
					border: 0, 0, 0, 0
					size_hint: None, None
					size: '30dp', '30dp'
					background_normal: './data/icons/RR_normal.png'
					background_down: './data/icons/RR_down.png'
					on_release: root.coarse_right()

		# Y Direction Controls
		BoxLayout:
			orientation: 'vertical'
			spacing: '5dp'

			Label:
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: 'Y: (mm)'

			# Set and Display Y Position	
			TextInput:
				id: y_pos_id
				multiline: False
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				halign: 'center'
				input_filter: 'float'
				text: ''
				on_text_validate: root.set_yposition(self.text)
				on_focus: if not self.focus: root.set_yposition(self.text)

			# Set Y Bookmark
			RoundedButton:
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: 'Set Y'
				tooltip_text: 'Save current Y position'
				on_release: root.set_ybookmark()

			# Goto Y Bookmark
			RoundedButton:
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: 'Go to Y'
				tooltip_text: 'Return to saved Y position'
				on_release: root.goto_ybookmark()

			# Y-Dir Controls
			BoxLayout:
				orientation: 'horizontal'
				spacing: '5dp'
				size_hint_y: None
				height: '30dp'

				Button: # COARSE FORWARD
					id: fast_down
					tooltip_text: 'Coarse upward'
					border: 0, 0, 0, 0
					size_hint: None, None
					size: '30dp', ' 30dp'
					background_normal: './data/icons/DD_normal.png'
					background_down: './data/icons/DD_down.png'
					on_release: root.coarse_back()
				Button: # FINE FORWARD
					border: 0, 0, 0, 0
					tooltip_text: 'Fine upward'
					size_hint: None, None
					size: '25dp', '30dp'
					background_normal: './data/icons/D_normal.png'
					background_down: './data/icons/D_down.png'
					on_release: root.fine_back()
				Button: # FINE BACK
					border: 0, 0, 0, 0
					tooltip_text: 'Fine downward'
					size_hint: None, None
					size: '25dp', '30dp'
					background_normal: './data/icons/U_normal.png'
					background_down: './data/icons/U_down.png'
					on_release: root.fine_fwd()
				Button: # COARSE BACK
					border: 0, 0, 0, 0
					tooltip_text: 'Coarse downward'
					size_hint: None, None
					size: '30dp', '30dp'
					background_normal: './data/icons/UU_normal.png'
					background_down: './data/icons/UU_down.png'
					on_release: root.coarse_fwd()

	# Stage Display
	FloatLayout:
		padding: '5dp'
		size_hint_y: None
		height: self.width * 2 / 3
		id: xy_stage_holder_id

	# Fill Space		
	Label:	


# ProtocolSettings - Settings for Labware within ImageSettings
# ------------------------------------------
<ProtocolSettings>:
    orientation: 'vertical'
	padding: '5dp'
	spacing: '5dp'

    canvas:
        Color:
            rgba: 0.1, 0.1, 0.1, 0.7
        Rectangle:
            size: self.size
            pos: self.pos

	ScrollView:
		scroll_type: ['bars']
		do_scroll_x: False
		pos_hint: {'top': 1.0}

		BoxLayout:
			pos_hint: {'top': 1.0}
			orientation: 'vertical'
			size_hint_y: None
			height: self.minimum_height
			padding: 0, 0, dp(8), 0
			spacing: dp(5)

			# Time Settings
			Label:
				text: 'Time Settings'
				tooltip_text: 'Set Interval and Duration for time lapse'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'
				color: [51/255, 181/255, 229/255, 1]

			# Capture Period
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Interval'
					tooltip_text: 'Interval between acquisitions'
					size_hint_x: None
					width: '95dp'
					font_size: '12sp'
				TextInput:
					id: capture_period
					multiline: False
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(5, '.3g')
					on_text_validate: root.update_period()
					on_focus: if not self.focus: root.update_period()
				Label:
					text: 'minutes'
					size_hint_x: None
					width: '95dp'
					font_size: '12sp'

			# Capture Duration
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Duration'
					tooltip_text: 'Total length of Protocol'
					size_hint_x: None
					width: '95dp'
					font_size: '12sp'
				TextInput:
					id: capture_dur
					multiline: False
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(48, '.3g')
					on_text_validate: root.update_duration()
					on_focus: if not self.focus: root.update_duration()
				Label:
					text: 'hours'
					size_hint_x: None
					width: '95dp'
					font_size: '12sp'

			# Select Labware
			Spinner:
				id: labware_spinner
				tooltip_text: 'Select Labware to be used in the Protocol'
				sync_height: True
				visible: True
				text: 'New'
				font_size: '12sp'
				option_cls: "SpinnerOption0"
				size_hint_y: None
				height: '30dp'
				text_autoupdate: True
				on_text: root.select_labware()


			# Load and Save Protocol
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'

				RoundedButton:
					text: 'New'
					tooltip_text: 'Create a New Protocol with the existing current Labware, Objective, and Channels set to acquire'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: root.new_protocol()
		
				FileChooseBTN:
					text: 'Load'
					tooltip_text: 'Load saved Protocol'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: self.choose('load_protocol')

				RoundedButton:
					text: 'Save'
					tooltip_text: 'Save Protocol'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					disabled: False
					on_release: root.save_protocol()

				FileSaveBTN:
					text: 'Save As'
					tooltip_text: 'Save Protocol with a new filename'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: self.choose('saveas_protocol')

			# Stage Display
			FloatLayout:
				padding: '5dp'
				size_hint_y: None
				height: '128dp'
				height: self.width * 2 / 3
				id: protocol_stage_holder_id

			# Protocol Name
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'

				Label:
					text: 'Protocol'
					tooltip_text: 'Current Protocol loaded'
					size_hint_x: None
					width: '75dp'
					font_size: '12sp'

				TextInput:
					id: protocol_filename
					text: ''
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					halign: 'center'
					multiline: False
					disabled: True
					hint_text: 'Protocol Filename'

			# Caputre Name Root
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'

				Label:
					text: 'Root'
					tooltip_text: 'Prefix of saved files'
					size_hint_x: None
					width: '75dp'
					font_size: '12sp'

				TextInput:
					id: capture_root
					text: ''
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					halign: 'center'
					multiline: False
					hint_text: 'Filename prefix'
					on_text_validate: root.update_capture_root(self.text)
					on_focus: if not self.focus: root.update_capture_root(self.text)
				

			# Step Name
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'

				Label:
					text: 'Step Name'
					tooltip_text: 'Label and Image filename for current Step'
					size_hint_x: None
					width: '75dp'
					font_size: '12sp'

				TextInput:
					id: step_name_input
					text: ''
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					halign: 'center'
					multiline: False
					hint_text: 'Step Name'
					on_text_validate: root.step_name_validation(self.text)
					on_focus: if not self.focus: root.step_name_validation(self.text)

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '3dp'
				Label:
					text: 'Step'
					tooltip_text: 'Step ID number in Protocol'
					size_hint_x: None
					width: '75dp'
					font_size: '12sp'

				Button:
					id: prev_step_btn
					tooltip_text: 'Move to previous Step'
					border: 0, 0, 0, 0
					size_hint: None, None
					size: '30dp', '30dp'
					pos_hint: {'center_x': 0.35, 'center_y': 0.5}
					background_normal: './data/icons/L_normal.png'
					background_down: './data/icons/L_down.png'
					on_release: root.prev_step()
				TextInput:
					id: step_number_input
					text: '0'
					tooltip_text: 'Enter desired Step ID number'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					halign: 'center'
					multiline: False
					input_filter: 'int'
					on_text_validate: root.handle_step_ui_input_change()
					on_focus: if not self.focus: root.handle_step_ui_input_change()
					valign: 'center'
				Label:
					text: 'of'
					size_hint_x: None
					width: '10dp'
					size_hint_y: None
					height: '30dp'
					font_size: '10sp'
					valign: 'center'
				TextInput:
					id: step_total_input
					text: '1'
					tooltip_text: 'Total number of Steps'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					halign: 'center'
					disabled: True
					multiline: False
					valign: 'center'
				Button:
					id: next_step_btn
					tooltip_text: 'Move to next Step'
					border: 0, 0, 0, 0
					size_hint: None, None
					size: '30dp', '30dp'
					pos_hint: {'center_x': 0.65, 'center_y': 0.5}
					background_normal: './data/icons/R_normal.png'
					background_down: './data/icons/R_down.png'
					on_release: root.next_step()
			
			# Modify individual Steps in Protocol
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'
				RoundedButton:
					id: delete_step_btn
					tooltip_text: 'Delete current Step'
					text: 'Delete'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: root.delete_step()
				RoundedButton:
					id: change_step_btn
					tooltip_text: 'Update settings for current Step including XYZ location,AF,AG/AE,Channel,turret position, and Step label'
					text: 'Change'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: root.modify_step()
				RoundedButton:
					id: add_step_btn
					tooltip_text: 'Add Step after current Step'
					text: 'Add'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					#on_release: root.append_step()
					on_release: root.insert_step(after_current_step=True)
					
			# Tiling
			BoxLayout:
				orientation: 'horizontal'
				id: tiling_box_layout_id
				size_hint_y: None
				height: '30dp'
				opacity: 1
				spacing: '5dp'
			
				Label:
					id: tiling_box_label_id
					text: 'Tiling'
					tooltip_text: 'Set tiling dimensions for New Protocols or untiled Steps application'
					size_hint_y: None
					height: '30dp'
					size_hint_x: None
					width: '75dp'
					font_size: '12sp'
					
				# Select tiling size
				Spinner:
					id: tiling_size_spinner
					sync_height: True
					text: ''
					tooltip_text: 'Set tiling dimensions for New Protocols or untiled Steps application'
					font_size: '12sp'
					size_hint_y: None
					height: '30dp'
					option_cls: "SpinnerOption0"
					text_autoupdate: True
					values: ''
					on_text: root.update_tiling_selection()

				RoundedButton:
					id: tiling_size_apply_id
					text: 'Apply'
					tooltip_text: 'Create tiles around untiled Steps'
					size_hint_y: None
					size_hint_x: None
					width: '50dp'
					height: '30dp'
					font_size: '12sp'
					on_release: root.apply_tiling()

			# Post-protocol creation Z-Stacking
			BoxLayout:
				orientation: 'horizontal'
				id: protocol_zstacking_box_layout_id
				size_hint_y: None
				height: '30dp'
				opacity: 1
				spacing: '5dp'
			
				Label:
					id: protocol_zstacking_box_label_id
					text: 'Z-Stacking'
					tooltip_text: 'Use Z-stack settings under Objective Settings'
					size_hint_y: None
					height: '30dp'
					size_hint_x: None
					width: '75dp'
					font_size: '12sp'

				Label:

				RoundedButton:
					id: protocol_zstacking_apply_id
					text: 'Apply'
					tooltip_text: 'Create Z-stack around unstacked Steps'
					size_hint_y: None
					size_hint_x: None
					width: '50dp'
					height: '30dp'
					font_size: '12sp'
					on_release: root.apply_zstacking()
								
			# Z-stack
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'
							
				CheckBox:
					id: acquire_zstack_id
					size_hint_x: None
					tooltip_text: 'Use Z-stack settings under Objective Settings\nfor New Protocol creation'
					width: '30dp'
					active: False
					on_release: root.update_acquire_zstack()

				Label:
					text: 'Enable Z-Stack'
					tooltip_text: 'Use Z-stack settings under Objective Settings\nfor New Protocol creation'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
			
			# Step Locations
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'
							
				CheckBox:
					id: show_step_locations_id
					size_hint_x: None
					width: '30dp'
					active: False
					tooltip_text: 'Display yellow cross for each Step'
					on_release: root.update_show_step_locations()

				Label:
					id: show_step_locations_label_id
					text: 'Show step locations'
					tooltip_text: 'Display yellow cross for each Step'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size

			# # Multiple exposure
			# BoxLayout:
			#     orientation: 'horizontal'
			#     size_hint_y: None
			#     height: '30dp'
			#     spacing: '5dp'
			
			#     Label:
			#         text: 'Exposures'
			#         size_hint_x: None
			#         width: '75dp'
			#         font_size: '12sp'
				
			#     Button:
			#         id: exposures_down_btn
			#         border: 0, 0, 0, 0
			#         size_hint: None, None
			#         size: '30dp', '30dp'
			#         pos_hint: {'center_x': 0.35, 'center_y': 0.5}
			#         background_normal: './data/icons/L_normal.png'
			#         background_down: './data/icons/L_down.png'
			#         on_release: root.exposures_down_button()
					
			#     TextInput:
			#         id: exposures_number_input
			#         text: '1'
			#         size_hint_y: None
			#         height: '30dp'
			#         font_size: '12sp'
			#         halign: 'center'
			#         multiline: False
			#         input_filter: 'int'
			#         #on_text_validate: root.set_exposures()
				
			#     Button:
			#         id: exposures_up_btn
			#         border: 0, 0, 0, 0
			#         size_hint: None, None
			#         size: '30dp', '30dp'
			#         pos_hint: {'center_x': 0.65, 'center_y': 0.5}
			#         background_normal: './data/icons/R_normal.png'
			#         background_down: './data/icons/R_down.png'
			#         on_release: root.exposures_up_button()
					
			# HIDDEN: "Use BF Focus for Fluorescence" — not yet tested, disabled for 4.0.0 release.
			# Re-enable after validation on hardware with multi-channel AF protocols.
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '0dp'
				opacity: 0
				disabled: True
				Label:
					font_size: '12sp'
					text: 'Use BF Focus for Fluorescence'
					tooltip_text: 'When enabled, autofocus runs only on the\nBrightfield channel and applies the result\nto all fluorescence channels at each well.'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: bf_af_for_fluorescence_btn
					tooltip_text: 'Use Brightfield autofocus result\nfor all fluorescence channels'
					size_hint: None, None
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_bf_af_for_fluorescence()

			RoundedToggleButton:
				id: run_autofocus_btn
				text: 'Autofocus All Steps'
				tooltip_text: 'Perform autofocus on all Steps\nand save focus for each Step\nno images are saved '
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				on_release: root.run_autofocus_scan_from_ui()
				disabled: False

			# Run Protocol
			Label:
				text: 'Execute Protocol'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp'
				spacing: '5dp'
				color: [51/255, 181/255, 229/255, 1]

			RoundedToggleButton:
				id: run_scan_btn
				text: 'Run One Scan'
				tooltip_text: 'Acquire one Interval of data'
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				on_release: root.run_scan_from_ui()

			RoundedToggleButton:
				id: run_protocol_btn
				text: 'Run Full Protocol'
				tooltip_text: 'Initiate complete Protocol for the full Duration'
				size_hint_y: None
				height: '60dp'
				halign: 'center'
				font_size: '12sp'
				on_release: root.run_protocol_from_ui()
				background_down: 'atlas://data/images/defaulttheme/button_pressed'

			# Engineering mode option
			BoxLayout:
				id: protocol_disable_image_saving_box_id
				height: '0dp'
				orientation: 'horizontal'
				size_hint_y: None
				height: '0dp'
				spacing: '5dp'
				opacity: 0
							
				CheckBox:
					id: protocol_disable_image_saving_id
					height: '0dp'
					size_hint_x: None
					width: '30dp'
					active: False

				Label:
					id: protocol_disable_image_saving_label_id
					height: '0dp'
					text: 'Disable image saving'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size

			Label:
				height: '50dp'
				size_hint_y: None

			# Button:
			# 	id: protocol_debug_btn
			# 	text: 'DEBUG'
			# 	tooltip_text: 'DEBUG'
			# 	size_hint_y: None
			# 	size_hint_x: None
			# 	width: '50dp'
			# 	height: '30dp'
			# 	font_size: '12sp'
			# 	on_release: root.debug_func()
	
	Widget:


<VideoCreationControls>:
	orientation: 'vertical'

	# Pad
	Widget:
		size_hint_y: None
		height: '30dp'

	FolderChooseBTN:
		text: 'Create video from Protocol data folder'
		tooltip_text: 'Combines sequential images into a video file'
		size_hint_y: None
		height: '30dp'
		font_size: '12sp'
		on_release: self.choose('apply_video_gen_to_folder')

	# Pad
	Widget:
		size_hint_y: None
		height: '5dp'
	
	# FPS
	BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '30dp'
		padding: '0dp'
		spacing: '5dp'
        Label:
            text: 'Frames/Second'
			halign: 'left'
			valign: 'middle'
			font_size: '12sp'
            size_hint_x: None
            width: '120dp'
			tooltip_text: 'Define FPS for video creation'
			
        TextInput:
            id: video_gen_fps_id
			multiline: False
			padding: ['2dp', (self.height-self.line_height)/2]
			halign: 'center'
			input_filter: 'int'
			text: '5'
			font_size: '12sp'

	# Timestamp Overlay
	BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '35dp'
		padding: '0dp'
		spacing: '5dp'
		Label:
			text: 'Overlay Timestamp'
			tooltip_text: 'Add real time values to lower left corner of video'
			halign: 'left'
			valign: 'middle'
			font_size: '12sp'
			text_size: self.size

		ToggleButton:
			id: enable_timestamp_overlay_btn
			tooltip_text: 'Add real time values to lower left corner of video'
			size_hint: None, None
			size: '45dp', '30dp'
			padding: ['2dp', (self.height-self.line_height)/2]
			border: 0, 0, 0, 0
			valign: 'middle'
			halign: 'right'
			background_normal: './data/icons/ToggleL.png'
			background_down: './data/icons/ToggleRW.png'
			state: 'down'

	# Empty widget to consume space at bottom of controls panel
	Widget:


<StitchControls>:
	orientation: 'vertical'

	# Pad
	Widget:
		size_hint_y: None
		height: '30dp'

	FolderChooseBTN:

		id: stitch_apply_btn
		text: 'Apply Stitching to Protocol Folder'
        tooltip_text: 'Assemble tiles into stitched montage image of abutted tiles'
		size_hint_y: None
		height: '30dp'
		font_size: '12sp'
		on_release: self.choose('apply_stitching_to_folder')
		disabled: False
	
	# Empty widget to consume space at bottom of controls panel
	Widget:


<ZProjectionControls>:
	orientation: 'vertical'

	# Pad
	Widget:
		size_hint_y: None
		height: '30dp'

	FolderChooseBTN:
		text: 'Apply Z-Projection to Z-stacks in folder'
		tooltip_text: 'Creates single image from Z-stacks'
		size_hint_y: None
		height: '30dp'
		font_size: '12sp'
		on_release: self.choose('apply_zprojection_to_folder')
	
	Widget:
		size_hint_y: None
		height: '5dp'

	# Projection Method
	BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '30dp'
		padding: '0dp'
		spacing: '5dp'
        Label:
            text: 'Method'
			halign: 'left'
			valign: 'middle'
			font_size: '12sp'
			tooltip_text: 'Select projection type'
            size_hint_x: None
            width: '120dp'
			
		Spinner:
			id: zprojection_method_spinner
			sync_height: True
	        text: 'Select'
			font_size:'12sp'
			option_cls: "SpinnerOption0"
			text_autoupdate: True
			values: '',
			text: ''

	# Empty widget to consume space at bottom of controls panel
	Widget:


<CompositeGenControls>:
	orientation: 'vertical'

	# Pad
	Widget:
		size_hint_y: None
		height: '30dp'

	FolderChooseBTN:
		text: 'Create fluorescence composites'
		tooltip_text: 'Combine fluorescence images and one transmitted image in Protocol data folder'
		size_hint_y: None
		height: '30dp'
		font_size: '12sp'
		on_release: self.choose('apply_composite_gen_to_folder')
	
	# Empty widget to consume space at bottom of controls panel
	Widget:

# PostProcessingAccordion - Settings for PostProcessingAccordion
# ------------------------------------------
<PostProcessingAccordion>:
    padding: '5dp'
    spacing: '5dp'
    orientation: 'vertical'
    canvas:
        Color:
            rgba: 0.1, 0.1, 0.1, 0.7
        Rectangle:
            size: self.size
    		pos: self.pos

	Accordion:
		orientation: 'vertical'
		id: post_processing_accordion_id

		AccordionItem:
			id: create_avi_accordion_id
			title: 'Create Video'
			on_collapse: root.accordion_collapse()
			background_normal: './data/icons/post_processing_background.png'
			collapse: False

			VideoCreationControls:
				id: video_creation_controls_id
			
		AccordionItem:
			id: stitch_accordion_id
			title: 'Stitch'
			on_collapse: root.accordion_collapse()
			background_normal: './data/icons/post_processing_background.png'

			StitchControls:
				id: stitch_controls_id

		AccordionItem:
			id: composite_gen_accordion_id
			title: 'Composite Generation'
			on_collapse: root.accordion_collapse()
			background_normal: './data/icons/post_processing_background.png'

			CompositeGenControls:
				id: composite_gen_controls_id

		AccordionItem:
			id: zprojection_accordion_id
			title: 'Z-Projection'
			on_collapse: root.accordion_collapse()
			background_normal: './data/icons/post_processing_background.png'

			ZProjectionControls:
				id: zprojection_controls_id

		# AccordionItem:
		# 	id: open_last_save_folder_accordion_id
		# 	title: 'Open Last Save Folder'
		# 	on_collapse: root.accordion_collapse()
		# 	background_normal: './data/icons/post_processing_background.png'

		# 	BoxLayout:
		# 		orientation: 'vertical'

		# 		# Pad
		# 		Widget:
		# 			size_hint_y: None
		# 			height: '30dp'

		# 		Button:
		# 			text:'Open Folder'
		# 			size_hint_y: None
		# 			height: '30dp'
		# 			font_size: '12sp'
		# 			on_release:root.open_folder()

		# 		Widget:

		AccordionItem:
			id: cell_count_accordion_id
			title: 'Object Analysis'
			on_collapse: root.accordion_collapse()
			background_normal: './data/icons/post_processing_background.png'

			BoxLayout:
				orientation: 'vertical'

				# Pad
				Widget:
					size_hint_y: None
					height: '30dp'

				RoundedButton:
					text:'Analyze'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					tooltip_text: 'Count and measure objects in images'
					on_release: root.open_cell_count()

				# Pad
				Widget:
					size_hint_y: None
					height: '5dp'

				RoundedButton:
					text: 'Plot'
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					on_release: root.open_graphing()
			
				Widget:


<Stage>:
	canvas:
		Line:
			width: dp(1)
			rectangle: (self.x, self.y, self.width, self.height)


<AccordionItemImageSettingsBlueControl>:
	id: Blue_accordion
	title: 'Blue Channel Control'
	on_collapse: root.accordion_collapse()
	LayerControl:
		id: Blue
		layer: 'Blue'
		bg_color: 0, .5, 1, 1
		stimulation_support: True

<AccordionItemImageSettingsGreenControl>:
	id: Green_accordion
	title: 'Green Channel Control'
	on_collapse: root.accordion_collapse()
	LayerControl:
		id: Green
		layer: 'Green'
		bg_color: .2, 0.8, 0.2, 1
		stimulation_support: True

<AccordionItemImageSettingsRedControl>:
	id: Red_accordion
	title: 'Red Channel Control'
	on_collapse: root.accordion_collapse()
	collapse: False
	LayerControl:
		id: Red
		layer: 'Red'
		bg_color: 1, 0.2, 0, 1
		stimulation_support: True

<AccordionItemImageSettingsDfControl>:
	id: DF_accordion
	title: 'Low Mag Darkfield Control'
	on_collapse: root.accordion_collapse()
	LayerControl:
		id: DF
		layer: 'DF'
		bg_color: 0.5, 0.5, 0.5,  1
		stimulation_support: False


<AccordionItemImageSettingsLumiControl>:
	id: Lumi_accordion
	title: 'Luminescence Control'
	on_collapse: root.accordion_collapse()
	collapse: False
	LayerControl:
		id: Lumi
		layer: 'Lumi'
		illumination_support: False
		stimulation_support: False
		autogain_support: False
		exposure_summing_support: True
		bg_color: 0, .5, 1, 1


# ImageSettings - view and edit control accordion
# ------------------------------------------
<ImageSettings>:
    orientation: 'horizontal'
    RelativeLayout:
        size_hint: None, None
        width: dp(30)
        height: dp(120)
        pos_hint: {'center_y': 0.5}
        ToggleButton:
            id: toggle_imagesettings
            size_hint: 1, 1
            background_normal: ''
            background_down: ''
            background_color: 0, 0, 0, 0
            on_press: root.toggle_settings()
            Image:
                source: './data/icons/left_arrow_left_arc.png' if toggle_imagesettings.state == 'normal' else './data/icons/right_arrow_left_arc.png'
                size_hint: None, None
                size: dp(30), dp(60)
                center_y: toggle_imagesettings.center_y
                x: toggle_imagesettings.x

    Accordion:
        orientation: 'vertical'
        id: accordion_id

        # BRIGHTFIELD SETTINGS
        AccordionItem:
			id: BF_accordion
            title: 'Brightfield Control'
			on_collapse: root.accordion_collapse()
            LayerControl:
                id: BF
                layer: 'BF'
                bg_color: 0.5, 0.5, 0.5,  1

       # PHASE CONTRAST SETTINGS
        AccordionItem:
			id: PC_accordion
            title: 'Phase Contrast Control'
			on_collapse: root.accordion_collapse()
            LayerControl:
                id: PC
                layer: 'PC'
                bg_color: 0.5, 0.5, 0.5,  1


# MicroscopeSettings - Settings for  Microscope within ImageSettings
# ------------------------------------------
<SpinnerOption0@SpinnerOption>:
    font_size: '12sp'

<MicroscopeSettings>:
    padding: '5dp'
    spacing: '5dp'
    orientation: 'vertical'
    canvas:
        Color:
            rgba: 0.1, 0.1, 0.1, 0.7
        Rectangle:
            size: self.size
            pos: self.pos

	ScrollView:
		scroll_type: ['bars']
		do_scroll_x: False
		pos_hint: {'top': 1.0}
		BoxLayout:
			orientation: 'vertical'
			size_hint_y: None
			height: self.minimum_height
			padding: 0, 0, dp(8), 0
			spacing: dp(5)
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Lumascope Model'
					tooltip_text: 'Lumi, LS820, LS850, and LS850T'
					size_hint_x: None
					width: '120dp'
					font_size: '12sp'
				Spinner:
					id: scope_spinner
					sync_height: True
					text: 'Select'
					font_size:'12sp'
					option_cls: "SpinnerOption0"
					text_autoupdate: True
					on_release: root.load_scopes()
					on_text: root.select_scope()

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Objective'
					tooltip_text: 'Current objective in the lightpath'
					size_hint_x: None
					width: '120dp'
					font_size: '12sp'
				Spinner:
					id: objective_spinner
					sync_height: True
					text: 'Select'
					font_size:'12sp'
					option_cls: "SpinnerOption0"
					text_autoupdate: True
					on_release: root.load_objectives()
					on_text: root.select_objective()

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Magnification'
					tooltip_text: 'Current objective magnification'
					size_hint_x: None
					width: '120dp'
					font_size: '12sp'
				TextInput:
					id: magnification_id
					multiline: False
					padding: ['5dp', (self.height-self.line_height)/2]
					halign: 'center'
					input_filter: 'int'
					text: '40'
					disabled: True
					font_size: '12sp'

			# Frame Size
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				padding: '0dp'
				spacing: '5dp'

				Label:
					text: 'Frame Size'
					tooltip_text: 'Camera sensor frame size in pixels'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '80dp'
					text_size: self.size

				TextInput:
					id: frame_width_id
					multiline: False
					padding: ['2dp', (self.height-self.line_height)/2]
					halign: 'center'
					input_filter: 'int'
					text: '1900'
					on_text_validate: root.frame_size()
					on_focus: if not self.focus: root.frame_size()
					font_size: '12sp'
				Label:
					text: 'x'
					tooltip_text: 'Camera sensor X and Y dimension\nframe size in pixels\n from 4 to 3860 in X and 2178 in Y\nbut 1600-2100 recommended'
					size_hint_x: None
					width: '15dp'
					font_size: '12sp'
					halign: 'center'
				TextInput:
					id: frame_height_id
					multiline: False
					padding: ['5dp', (self.height-self.line_height)/2]
					halign: 'center'
					input_filter: 'int'
					text: '1900'
					on_text_validate: root.frame_size()
					on_focus: if not self.focus: root.frame_size()
					font_size: '12sp'
			
			# Field of View
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Field of View'
					tooltip_text: 'FOV calculated from magnification and frame size'
					size_hint_x: None
					width: '120dp'
					font_size: '12sp'

				TextInput:
					id: field_of_view_width_id
					multiline: False
					padding: ['2dp', (self.height-self.line_height)/2]
					halign: 'center'
					input_filter: 'int'
					text: ''
					font_size: '12sp'
					disabled: True
				Label:
					text: 'x'
					size_hint_x: None
					width: '15dp'
					font_size: '12sp'
					halign: 'center'
				TextInput:
					id: field_of_view_height_id
					multiline: False
					padding: ['5dp', (self.height-self.line_height)/2]
					halign: 'center'
					input_filter: 'int'
					text: ''
					font_size: '12sp'
					disabled: True
				Label:
					text: ' um'
					size_hint_x: None
					width: '15dp'
					font_size: '12sp'
					halign: 'center'


			# BoxLayout:
			# 	orientation: 'horizontal'
			# 	size_hint_y: None
			# 	height: '30dp'
			# 	Button:
			# 		id: reconnect_btn
			# 		size_hint_y: None
			# 		height: '30dp'
			# 		font_size: '12sp'
			# 		text: 'Reconnect'
			# 		tooltip_text: 'Restart connection to microscope'
			# 		on_release: root.reconnect()

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Live Image Format'
					tooltip_text: 'Choose between TIFF and OME-TIFF\nfor live image capture'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
					font_size: '12sp'
				Spinner:
					id: live_image_output_format_spinner
					sync_height: True
					text: 'Select'
					font_size:'12sp'
					option_cls: "SpinnerOption0"
					text_autoupdate: True
					on_text: root.select_live_image_output_format()
					values: ('TIFF', 'OME-TIFF')

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Sequenced Image Format'
					tooltip_text: 'Choose between TIFF, OME-TIFF or\nImageJ Hyperstack with TIFF\nfor Protocol image capture'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
					font_size: '12sp'
				Spinner:
					id: sequenced_image_output_format_spinner
					sync_height: True
					text: 'Select'
					font_size:'12sp'
					option_cls: "SpinnerOption0"
					text_autoupdate: True
					on_text: root.select_sequenced_image_output_format()
					values: ('TIFF', 'OME-TIFF', 'ImageJ Hyperstack')

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Video Recording\nFormat'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
					font_size: '12sp'
				Spinner:
					id: video_recording_format_spinner
					sync_height: True
					text: 'Select'
					font_size:'12sp'
					option_cls: "SpinnerOption0"
					text_autoupdate: True
					on_text: root.select_video_recording_format()
					values: ('mp4', 'Frames')

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: '12 Bit Mode'
					tooltip_text: 'Capture and save images at 12-bit depth\n(4096 levels) instead of 8-bit (256 levels)'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: enable_full_pixel_depth_btn
					tooltip_text: 'Save all images as 12-bit TIFF'
					size_hint: None, None
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_full_pixel_depth_state()

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: 'False Color in Saved 12-bit'
					tooltip_text: 'Save 12-bit fluorescence images as 3-channel\nRGB for false color in all viewers.\nIncreases file size ~3x.'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: false_color_16bit_btn
					tooltip_text: 'Save 12-bit fluorescence as 3-channel RGB\nfor false color in all viewers (3x file size)'
					size_hint: None, None
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_false_color_16bit_state()

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					text: 'Binning'
					tooltip_text: 'Add adjacent pixels together for increased sensitivity\nsacrificing resolution'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
					font_size: '12sp'
				Spinner:
					id: binning_spinner
					sync_height: True
					text: 'Select'
					font_size:'12sp'
					option_cls: "SpinnerOption0"
					text_autoupdate: True
					on_release: root.load_binning_sizes()
					on_text: root.select_binning_size()

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: 'Enable Scale Bar'
					tooltip_text: 'Show scale bar in lower right corner of image'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: enable_scale_bar_btn
					tooltip_text: 'Show scale bar in lower right corner of image'
					size_hint: None, None
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_scale_bar_state()
					state: 'normal'
					
			# Separate Folders
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
							
				Label:
					text: 'Save channels in separate folders'
					tooltip_text: "Save each channels' images in separate folders"
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size

				ToggleButton:
					id: separate_folder_per_channel_id
					size_hint: None, None
					tooltip_text: "Save each channels' images in separate folders"
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_separate_folders_per_channel()
					state: 'normal'

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: 'Enable Crosshairs'
					tooltip_text: 'Display a bullseye pattern over the live image \n(Bullseye will not be in saved images)'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: enable_crosshairs_btn
					tooltip_text: 'Display a bullseye pattern over the live image \n(Bullseye will not be in saved images)'
					size_hint: None, None
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_crosshairs_state()
					state: 'normal'

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: 'Live Image Contrast Stretching'
					tooltip_text: 'Expand pixel brightness histogram to full dynamic range,\ndoes not effect saved image'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: enable_live_image_histogram_equalization_btn
					tooltip_text: 'Show image with full dynamic range pixel brightness histogram\nsaved image may appear black but this shows what information is in the image\nif expanded post acquisition'
					size_hint: None, None
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_live_image_histogram_equalization()
					state: 'normal'


			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: 'Show Tooltips'
					tooltip_text: 'Display hint while hovering over controls'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: show_tooltips_btn
					size_hint: None, None
					tooltip_text: 'Display hint while hovering over controls'
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_show_tooltips()
					state: 'normal'
			
			BoxLayout:
				id: acceleration_control_box
				size_hint_y: None
				height: '30dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: not self.visible
				visible: True
				orientation: 'horizontal'
				Label:
					id: acceleration_pct_label
					text: 'Acceleration Max (%)'
					tooltip_text: 'Maximum acceleration percentage for X-Y stage'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
					font_size: '12sp'
				ModSlider:
					id: acceleration_pct_slider
					min: 1
					max: 100
					value: 100
					step: 1
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					#value_track_color: root.bg_color
					value_track_width: dp(5)
					on_release: root.acceleration_pct_slider() # on_touch_move # on_release
				TextInput:
					id: acceleration_pct_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'int'
					text: format(acceleration_pct_slider.value)
					on_text_validate: root.acceleration_pct_text()
					on_focus: if not self.focus: root.acceleration_pct_text()
				
			BoxLayout:
				size_hint_y: None
				height: '30dp'
				orientation: 'horizontal'
				Label:
					text: 'Live View FPS'
					tooltip_text: 'Maximum frames per second for live camera display'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
					font_size: '12sp'
				ModSlider:
					id: live_view_fps_slider
					min: 5
					max: 65
					value: 30
					step: 5
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_width: dp(5)
					on_release: root.live_view_fps_slider()
				TextInput:
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					text: 'Max' if int(live_view_fps_slider.value) > 60 else format(int(live_view_fps_slider.value))
					readonly: True

			BoxLayout:

				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: 'Protocol LED On'
					tooltip_text: 'Automatically turn on LED for each protocol step'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: protocol_led_on_btn
					size_hint: None, None
					tooltip_text: 'Automatically turn on LED for each protocol step'
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_protocol_led_on()
					state: 'normal'

			BoxLayout:

				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				Label:
					font_size: '12sp'
					text: 'Stimulation Settings'
					tooltip_text: 'Enable stimulation features globally'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: stimulation_settings_btn
					size_hint: None, None
					tooltip_text: 'Enable stimulation features globally'
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_stimulation_settings()
					state: 'normal'

			BoxLayout:
				height: '30dp'
				size_hint_y: None
				orientation: 'horizontal'
				opacity: 0
				
			BoxLayout:
				id: enable_bullseye_box_id
				opacity: 0
				orientation: 'horizontal'
				size_hint_y: None
				height: '0dp'
				Label:
					font_size: '12sp'
					text: 'Enable Bullseye Mode'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: enable_bullseye_btn_id
					size_hint: None, None
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleRW.png'
					on_release: root.update_bullseye_state()

			# Support Report
			BoxLayout:
				size_hint_y: None
				height: dp(48)
				padding: dp(8)
				RoundedButton:
					id: btn_support_report
					text: 'Generate Support Report'
					font_size: '12sp'
					on_release: root.generate_support_report()

			Label:

# LayerControl - Settings for Layers within ImageSettings
# ------------------------------------------
<LayerControl>:
    padding: '10dp'
    spacing: '5dp'
    orientation: 'vertical'
    canvas:
        Color:
            rgba: 0.1, 0.1, 0.1, 0.7
        Rectangle:
            size: self.size
            pos: self.pos
  

	ScrollView:
		scroll_type: ['bars']
		do_scroll_x: False
		BoxLayout:
			orientation: 'vertical'
			size_hint_y: None
			height: self.minimum_height
			padding: 0, 0, dp(8), 0
			spacing: dp(5)
			
			# Illumination
			Label:
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1
						pos: self.x, self.y+self.height

				text:'Illumination'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				disabled: False if self.visible else True
				# spacing: '5dp'
				color: root.bg_color
				opacity: 1 if self.visible else 0
				visible: True if root.illumination_support else False

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp'
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.illumination_support else False

				Label:
					id: LED_label
					font_size: '12sp'
					text: 'Enable LED'
					tooltip_text: 'Turn on channel LED'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				ToggleButton:
					id: enable_led_btn
					size_hint: None, None
					tooltip_text: 'Turn on channel LED'
					size: '45dp', '30dp'
					border: 0, 0, 0, 0
					valign: 'middle'
					background_normal: './data/icons/ToggleL.png'
					background_down: './data/icons/ToggleR.png'
					on_release: root.update_led_state()

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp'
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.illumination_support else False

				Label:
					text: 'Illumination (mA)'
					halign: 'left'
					tooltip_text: 'Adjust LED brightness'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '95dp'
					text_size: self.size
				ModSlider:
					id: ill_slider
					min: 0.
					max: 500.
					value: 100.
					step: 1.
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_value: root.ill_slider() # on_touch_move # on_release
				TextInput:
					id: ill_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(ill_slider.value, '.4g')
					on_text_validate: root.ill_text()
					on_focus: if not self.focus: root.ill_text()

			# Stimulation
			Label:
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1
						pos: self.x, self.y+self.height
					
				color: root.bg_color
				opacity: 1 if self.visible else 0
				visible: True if root.stimulation_support else False

				text:'Stimulation'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				disabled: False if self.visible else True
				# spacing: '5dp'
				


			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.stimulation_support else False
				
				CheckBox:
					id: stim_enable_btn
					group: f'{root.layer}_stim_group'
					size_hint_x: None
					width: '30dp'
					active: False
					on_release: root.update_stim_enable()
					allow_no_selection: False
				Label:
					text: 'Enable'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size

				CheckBox:
					id: stim_disable_btn
					group: f'{root.layer}_stim_group'
					size_hint_x: None
					width: '30dp'
					active: True
					on_release: root.update_stim_enable()
					allow_no_selection: False
				Label:
					text: 'Disable'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
			
			BoxLayout:
				id: stim_freq_box
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_stim_controls else False

				Label:
					text: 'Frequency (Hz)'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '95dp'
					text_size: self.size
				ModSlider:
					id: stim_freq_slider
					min: 0.5
					max: 6.
					value: 1.
					step: 0.25
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_release: root.stim_freq_slider() # on_touch_move # on_release
				TextInput:
					id: stim_freq_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(stim_freq_slider.value, '.4g')
					on_text_validate: root.stim_freq_text()
					on_focus: if not self.focus: root.stim_freq_text()

			BoxLayout:
				id: stim_pulse_width_box
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_stim_controls else False

				Label:
					text: 'Pulse Width (ms)'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '95dp'
					text_size: self.size
				ModSlider:
					id: stim_pulse_width_slider
					min: 5
					max: 25.
					value: 10.
					step: 1.
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_release: root.stim_pulse_width_slider() # on_touch_move # on_release
				TextInput:
					id: stim_pulse_width_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(stim_pulse_width_slider.value, '.4g')
					on_text_validate: root.stim_pulse_width_text()
					on_focus: if not self.focus: root.stim_pulse_width_text()

			
			BoxLayout:
				id: stim_pulse_count_box
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_stim_controls else False

				Label:
					text: 'Pulse Count'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '95dp'
					text_size: self.size
				ModSlider:
					id: stim_pulse_count_slider
					min: 1
					max: 300
					value: 1
					step: 1
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_release: root.stim_pulse_count_slider() # on_touch_move # on_release
				TextInput:
					id: stim_pulse_count_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(stim_pulse_count_slider.value, '.4g')
					on_text_validate: root.stim_pulse_count_text()
					on_focus: if not self.focus: root.stim_pulse_count_text()

			# Camera
			Label:
				visible: True if root.show_camera_controls else False
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1 if root.illumination_support else 0
						pos: self.x, self.y+self.height
				text:'Camera'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				# spacing: '5dp'
				color: root.bg_color

			# Auto Gain/Exp
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp'
				disabled: False if self.visible else True
				opacity: 1 if self.visible else 0
				visible: True if root.autogain_support and root.show_camera_controls else False

				CheckBox:
					id: auto_gain
					size_hint_x: None
					width: '25dp'
					tooltip_text: 'Turn on autogain/exposure for this channel\nillumination should be between 10-30 for transmitted channels\nand 50-400 for fluorescence channels'
					active: False
					on_release: root.update_auto_gain()

				Label:
					text: 'Auto Gain/Exp'
					tooltip_text: 'Turn on autogain/exposure for this channel\nillumination should be between 10-30 for transmitted channels\nand 50-400 for fluorescence channels\nexposure will be minimzed with gain compensation'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '100dp'
					text_size: self.size
				

			# Gain
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls else False

				Label:
					text: 'Gain (dB)'
					tooltip_text: 'Adjust camera gain setting'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '95dp'
					text_size: self.size
				ModSlider:
					id: gain_slider # 0 to 48, default 0, based on camera limits
					min: 0.
					max: 48.
					value: 0.
					step: 0.1
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_value: root.gain_slider()
				TextInput:
					id: gain_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(gain_slider.value, '.3g')
					on_text_validate: root.gain_text()
					on_focus: if not self.focus: root.gain_text()

			# Exposure
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls else False

				Label:
					text: 'Exposure (ms)'
					tooltip_text: 'Adjust camera exposure setting'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '95dp'
					text_size: self.size
				ModSlider:
					id: exp_slider
					min: 0.01
					max: 1000. # values are in ms
					value: 100.
					step: 0.01
					# # This was to create a log scale
					# min: -2. # minimum allowable by camera 10.0 us = 0.01 ms -> 10^-2 log-10 scale
					# max: 3. # maximum, allowable by camera 1000000.0 us = 1000.0 ms -> 10^3 -> 10^-2 log-10 scale
					# value: 2. # 10^2 -> 100 ms exposure
					# step: 0.01
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_value: root.exp_slider()
				TextInput:
					id: exp_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(exp_slider.value, '.4g')
					# text: format(10 ** exp_slider.value, '.3g')
					on_text_validate: root.exp_text()
					on_focus: if not self.focus: root.exp_text()
				
			# Exposure Summing
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp'
				opacity: 1 if self.visible else 0
				disabled: not self.visible
				visible: True if root.exposure_summing_support and root.show_camera_controls else False

				Label:
					text: 'Sum'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '80dp'
					text_size: self.size
				ModSlider:
					id: sum_slider
					min: 1
					max: 100
					value: 1
					step: 1
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_release: root.sum_slider()
				TextInput:
					id: sum_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: "int"
					text: "{:d}".format(int(sum_slider.value))
					on_text_validate: root.sum_text()
					on_focus: if not self.focus: root.sum_text()


			# Focus
			Label:
				visible: True if root.show_camera_controls else False
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1
						pos: self.x, self.y+self.height
				text:'Focus'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				color: root.bg_color
			
			# Focus Settings
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls else False

				RoundedButton:
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					text: 'Save Focus'
					tooltip_text: 'Save current focus to use in Protocol and Manual Composite Acquisition'
					on_release: root.save_focus()
				RoundedButton:
					size_hint_y: None
					height: '30dp'
					font_size: '12sp'
					text: 'Go to Focus'
					tooltip_text: 'Go to the previously saved focus'
					on_release: root.goto_focus()
			
			# Protocol Settings
			Label:
				visible: True if root.show_camera_controls else False
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1
						pos: self.x, self.y+self.height
				text:'Protocol Settings'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				color: root.bg_color

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls else False

				CheckBox:
					id: autofocus
					size_hint_x: None
					width: '30dp'
					active: True
					tooltip_text: 'Enable image contrast-based autofocus in Protocol for this channel and manual Composite acquisition'
					on_release: root.update_autofocus()
				Label:
					text: 'Auto Focus'
					tooltip_text: 'Enable image contrast-based autofocus in Protocol for this channel and manual Composite acquisition'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
			
			# Video Settings
			Label:
				visible: True if root.show_camera_controls else False
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1
						pos: self.x, self.y+self.height
				text:'Video Settings'
				tooltip_text: 'Define length of Protocol video at each Interval'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				color: root.bg_color

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls else False

				Label:
					text: 'Duration (s)'
					tooltip_text: 'Recording time for Protocol videos\n30 seconds maximum'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '95dp'
					text_size: self.size
				ModSlider:
					id: video_duration_slider
					min: 1
					max: 30
					value: 5
					step: 1
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_release: root.video_duration_slider()
				TextInput:
					id: video_duration_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(video_duration_slider.value, '.4g')
					on_text_validate: root.video_duration_text()
					on_focus: if not self.focus: root.video_duration_text()

			# Acquire Settings
			Label:
				visible: True if root.show_camera_controls else False
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1
						pos: self.x, self.y+self.height
				text:'Acquire Settings'
				tooltip_text: 'Choose channel activity for Protocol'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				color: root.bg_color

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls else False
				
				CheckBox:
					id: acquire_none
					group: f'{root.layer}_acquire_group'
					size_hint_x: None
					width: '30dp'
					active: True
					tooltip_text: 'Channel not used in Protocol or Manual Composite Acquisition'
					on_release: root.update_acquire()
					allow_no_selection: False
				Label:
					text: 'None'
					tooltip_text: 'Channel not used in Protocol or Manual Composite Acquisition'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size

				CheckBox:
					id: acquire_image
					group: f'{root.layer}_acquire_group'
					size_hint_x: None
					width: '30dp'
					active: True
					tooltip_text: 'Acquire image in Protocol'
					on_release: root.update_acquire()
					allow_no_selection: False
				Label:
					text: 'Image'
					tooltip_text: 'Acquire image in Protocol'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				
				CheckBox:
					id: acquire_video
					group: f'{root.layer}_acquire_group'
					size_hint_x: None
					width: '30dp'
					active: True
					tooltip_text: 'Acquire video in Protocol'
					on_release: root.update_acquire()
					allow_no_selection: False
				Label:
					text: 'Video'
					tooltip_text: 'Acquire video in Protocol'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size

		    # Composite Brightness Threshold
			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp' if self.visible else 0
				padding: '0dp'
				spacing: '5dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls and root.show_cbt else False

				Label:
					id: composite_threshold_label
					text: 'CBT (%)'
					halign: 'left'
					valign: 'middle'
					font_size: '12sp'
					size_hint_x: None
					width: '50dp'
					text_size: self.size
					tooltip_text: 'Minimum Composite Brightness Threshold for Composite acquisition'
				ModSlider:
					id: composite_threshold_slider # 0 to 100
					min: 0.
					max: 100.
					value: 0.
					step: 1
					cursor_size: '20dp','20dp'
					cursor_image: './data/icons/slider_cursor.png'
					track_width: dp(5)
					value_track: True
					value_track_color: root.bg_color
					value_track_width: dp(5)
					on_release: root.composite_threshold_slider()
				TextInput:
					id: composite_threshold_text
					size_hint_x: None
					width: '45dp'
					multiline: False
					font_size: '12sp'
					padding: ['4dp', (self.height-self.line_height)/2]
					halign: 'right'
					input_filter: 'float'
					text: format(composite_threshold_slider.value, '.3g')
					on_text_validate: root.composite_threshold_text()
					on_focus: if not self.focus: root.composite_threshold_text()
				
			FloatLayout:
				padding: '0dp'
				spacing: '5dp'
				size_hint_y: None
				height: '128dp' if self.visible else 0
				opacity: 1 if self.visible else 0
				disabled: False if self.visible else True
				visible: True if root.show_camera_controls else False

				Histogram:
					id: histo_id
					pos_hint:{'center_x':0.5, 'center_y':0.5}
					bg_color: root.bg_color
					layer: root.layer

			Label:
			    id: image_stats_mean_id
				size_hint_y: None
				height: '0dp'
				pos_hint:{'left': 0.1}
				halign: 'left'
				size_hint_x: None
				text: ''
				

			Label:
			    id: image_stats_stddev_id
				size_hint_y: None
				height: '0dp'
				pos_hint:{'left': 0.1}
				halign: 'left'
				size_hint_x: None
				text: ''

			Label:
			    id: image_af_score_id
				size_hint_y: None
				height: '0dp'
				pos_hint:{'left': 0.1}
				halign: 'left'
				size_hint_x: None
				text: ''

            # Display Properties
			Label:
				canvas:
					Color:
						rgba: root.bg_color
					Rectangle:
						size: self.width, 1
						pos: self.x, self.y+self.height
				text:'Display Properties'
				tooltip_text: 'Histogram log display and false color channel images'
				font_size: '16sp'
				size_hint_y: None
				height: '30dp'
				color: root.bg_color

			BoxLayout:
				orientation: 'horizontal'
				size_hint_y: None
				height: '30dp'
				padding: '0dp'
				spacing: '5dp'

				CheckBox:
					id: false_color
					size_hint_x: None
					width: '30dp'
					active: True
					tooltip_text: 'Apply false emission color to image'
					on_release: root.false_color()
				Label:		
					id: false_color_label
					font_size: '12sp'
					text: 'False Color'
					tooltip_text: 'Apply false emission color to image'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
				CheckBox:
					id: logHistogram_id
					size_hint_x: None
					width: '30dp'
					active: True
					tooltip_text: 'Change X-axis of histogram to log scale'
					state: 'normal'
					disabled: False if self.visible else True
					opacity: 1 if self.visible else 0
					visible: True if root.show_camera_controls else False
				Label:
					text: 'Log'
					tooltip_text: 'Change X-axis of histogram to log scale'
					font_size: '12sp'
					halign: 'left'
					valign: 'middle'
					text_size: self.size
					disabled: False if self.visible else True
					opacity: 1 if self.visible else 0
					visible: True if root.show_camera_controls else False

			Label:

<Histogram>:
	canvas:
		Color:
			rgba: root.bg_color
		Line:
			width: dp(1)
			rectangle: (self.x, self.y, self.width, self.height)

<GraphingControls>:
	orientation: 'horizontal'

	# Controls
	BoxLayout:
		orientation: 'vertical'
		size_hint_x: 0.35

		# Pad
		Widget:
			size_hint_y: None
			height: '10dp'
		
		# Select TSV to graph
		FileChooseBTN:
			markup: True
			text: '[b]Load Object-Analysis Data[/b]'
			size_hint_x: 0.97
			size_hint_y: None
			height: '40dp'
			font_size: '16sp'
			on_release: self.choose('load_graphing_data')
		
		# Pad
		Widget:
			size_hint_y: None
			height: '20dp'

		# Graph Title
		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 0.97

			Label:
				markup: True
				text: '[b]Graph Title[/b] '
				size_hint_x: None
				width: '70dp'
				font_size: '12sp'
				halign: 'left'

			TextInput:
				id: graph_title_input
				valign: 'center'
				text: root.graph_title
				width: '80dp'
				font_size: '12sp'
				multiline: False
				padding: ['7dp', (self.height-self.line_height)/2]
				on_text: root.update_graph_title()

		# Pad
		Widget:
			size_hint_y: None
			height: '25dp'

		# X-Axis Labeling
		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 0.97

			Label:
				markup: True
				text: '[b]X-Axis Label[/b] '
				size_hint_x: None
				width: '70dp'
				font_size: '12sp'
				halign: 'left'

			TextInput:
				id: x_axis_label_input
				valign: 'center'
				text: root.x_axis_label
				width: '80dp'
				font_size: '12sp'
				multiline: False
				padding: ['7dp', (self.height-self.line_height)/2]
				on_text: root.update_x_axis_label()

		# Pad
		Widget:
			size_hint_y: None
			height: '0dp'

		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 0.97

			Label:
				markup: True
				text: '[b]X-Axis Data[/b]'
				size_hint_x: None
				width: '70dp'
				font_size: '12sp'
				halign: 'left'

			Spinner:
				id: graphing_x_axis_spinner
				text_autoupdate: True
				sync_height: True
				size_hint_y: None
				font_size: '12sp'
				height: '30dp'
				text: 'X-Axis'
				on_text: root.set_x_axis()
				values: root.available_axes

		# Pad
		Widget:
			size_hint_y: None
			height: '25dp'

		# Y-Axis Labeling
		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 0.97

			Label:
				markup: True
				text: '[b]Y-Axis Label[/b] '
				size_hint_x: None
				width: '70dp'
				font_size: '12sp'
				halign: 'left'

			TextInput:
				id: y_axis_label_input
				valign: 'center'
				text: root.y_axis_label
				width: '80dp'
				font_size: '12sp'
				multiline: False
				padding: ['7dp', (self.height-self.line_height)/2]
				on_text: root.update_y_axis_label()

		# Pad
		Widget:
			size_hint_y: None
			height: '0dp'

		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 0.97

			Label:
				markup: True
				text: '[b]Y-Axis Data[/b]'
				size_hint_x: None
				width: '70dp'
				font_size: '12sp'
				halign: 'left'

			Spinner:
				id: graphing_y_axis_spinner
				text_autoupdate: True
				sync_height: True
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: 'Y-Axis'
				on_text: root.set_y_axis()
				values: root.available_axes

		# Pad
		Widget:
			size_hint_y: None
			height: '10dp'

		# Trendline
		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 0.97

			Label:
				markup: True
				text: '[b]Trendline[/b]'
				size_hint_x: None
				width: '70dp'
				font_size: '12sp'
				halign: 'left'
			
			Spinner:
				id: trendline_spinner
				text_autoupdate: True
				sync_height: True
				size_hint_y: None
				height: '30dp'
				font_size: '12sp'
				text: ''
				on_text: root.update_trendline()
				values: ('None', 'Linear', 'Quadratic', 'Exponential', 'Power', 'Logarithmic')

		# Pad
		Widget:
			size_hint_y: None
			height: '25dp'

		# Save graph as png
		FileSaveBTN:
			markup: True
			text: '[b]Save Graph as PNG[/b]'
			size_hint_y: None
			height: '40dp'
			font_size: '16sp'
			size_hint_x: 0.97
			on_release: self.choose('save_graph')


		# Empty Widget to consume space at bottom of controls panel
		Widget:

	# Graphing Area
	BoxLayout:
		id: graphing_area
		orientation: 'vertical'
		size_hint_x: 0.65
		size_hint_y: 0.99
		canvas:
			Color:
				rgba: 0,0,0,0

		

<CellCountControls>:
	orientation: 'horizontal'

	# Controls
	BoxLayout: 
		orientation: 'vertical'
		size_hint_x: 0.35

		# Pad
		Widget:
			size_hint_y: None
			height: '30dp'

		# Select image to load
		FileChooseBTN:
			text: 'Load Image'
			tooltip_text: 'Select example image to configure analysis settings'
			size_hint_y: None
			height: '30dp'
			font_size: '12sp'
			on_release: self.choose('load_cell_count_input_image')

		# Pad
		Widget:
			size_hint_y: None
			height: '30dp'

		# Pixel size
		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 1

			Label:
				text: 'Pixel Ratio'
				tooltip_text: 'Select from objective magnification table in manual'
				size_hint_x: None
				width: '70dp'
				font_size: '12sp'
				halign: 'left'

			TextInput:
				id: text_cell_count_pixels_per_um_id
				valign: 'center'
				text: "1.0"
				size_hint_x: None
				size_hint_y: None
				height: '35dp'
				width: '60dp'
				multiline: False
				on_text: root.pixel_conversion_adjustment()
			
			Label:
				text: 'pixels/μm'
				tooltip_text: 'Camera pixels per micron of sample'
				size_hint_x: None
				width: '100dp'
				font_size: '12sp'
				halign: 'left'

		# Enable fluorescence mode
		BoxLayout:
			orientation: 'horizontal'
			size_hint_y: None
			height: '40dp'
			size_hint_x: 1
			CheckBox:
				id: cell_count_fluorescent_mode_id
				size_hint_x: None
				width: '40dp'
				active: True
				on_release: root.flourescent_mode_toggle()

			Label:
				text: 'Fluorescent Image'
				tooltip_text: 'Is the image fluorescence or transmitted\nbright objects or bright background'
				size_hint_x: None
				width: '100dp'
				font_size: '12sp'
	
		# Slider Controls
		BoxLayout:
			orientation: 'vertical'
			size_hint_y: None
			height: '225dp'

			# Threshold slider
			BoxLayout:
				orientation: 'horizontal'

				Label:
					text: 'Threshold'
					tooltip_text: 'Object threshold against background'
					size_hint_x: None
					width: '90dp'
					font_size: '12sp'
				
				ModSlider:
					id: slider_cell_count_threshold_id
					min: 0
					max: 100
					step: 1
					orientation: 'horizontal'
					on_release: root.slider_adjustment_threshold()
				Label:
					text: f"{str(int(slider_cell_count_threshold_id.value))} %"
					width: '60dp'
					font_size: '12sp'
			
			# Area slider
			BoxLayout:
				orientation: 'horizontal'

				Label:
					text: 'Area'
					tooltip_text: 'Area limits for objects'
					size_hint_x: None
					width: '90dp'
					font_size: '12sp'

				RangeSlider:
					id: slider_cell_count_area_id
					min: 0
					max: 100
					step: 1
					orientation: 'horizontal'
					value1: 0
					value2: 100
					on_touch_up: root.slider_adjustment_area()
					on_touch_move: root.slider_adjustment_area()
				Label:
					id: label_cell_count_area_id
					width: '60dp'
					font_size: '12sp'

			# Perimeter slider
			BoxLayout:
				orientation: 'horizontal'

				Label:
					text: 'Perimeter'
					tooltip_text: 'Perimeter limits for objects'
					size_hint_x: None
					width: '90dp'
					font_size: '12sp'
				
				RangeSlider:
					id: slider_cell_count_perimeter_id
					min: 0
					max: 100
					step: 1
					orientation: 'horizontal'
					value1: 0
					value2: 100
					on_touch_up: root.slider_adjustment_perimeter()
					on_touch_move: root.slider_adjustment_perimeter()
				Label:
					id: label_cell_count_perimeter_id
					width: '60dp'
					font_size: '12sp'

			# Sphericity slider
			BoxLayout:
				orientation: 'horizontal'

				Label:
					text: 'Sphericity'
					tooltip_text: 'Roundness limits for objects'
					size_hint_x: None
					width: '90dp'
					font_size: '12sp'
				
				RangeSlider:
					id: slider_cell_count_sphericity_id
					min: 0
					max: 1.0
					step: 0.01
					orientation: 'horizontal'
					value1: 0
					value2: 1.0
					on_touch_up: root.slider_adjustment_sphericity()
				Label:
					id: label_cell_count_sphericity_id
					text: f"{round(slider_cell_count_sphericity_id.value[0],2)}-{round(slider_cell_count_sphericity_id.value[1],2)}"
					width: '60dp'
					font_size: '12sp'

			# Min Intensity slider
			BoxLayout:
				orientation: 'horizontal'

				Label:
					text: 'Min Intensity'
					tooltip_text: 'Minimum intensity for objects'
					size_hint_x: None
					width: '90dp'
					font_size: '12sp'
				
				RangeSlider:
					id: slider_cell_count_min_intensity_id
					min: 0
					max: 100
					step: 1
					orientation: 'horizontal'
					value1: 0
					value2: 100
					on_touch_up: root.slider_adjustment_min_intensity()
				Label:
					id: label_cell_count_min_intensity_id
					text: f"{int(slider_cell_count_min_intensity_id.value[0])}-{int(slider_cell_count_min_intensity_id.value[1])} %"
					width: '60dp'
					font_size: '12sp'

			# Mean Intensity slider
			BoxLayout:
				orientation: 'horizontal'

				Label:
					text: 'Mean Intensity'
					tooltip_text: 'Mean intensity for objects'
					size_hint_x: None
					width: '90dp'
					font_size: '12sp'
				
				RangeSlider:
					id: slider_cell_count_mean_intensity_id
					min: 0
					max: 100
					step: 1
					orientation: 'horizontal'
					value1: 0
					value2: 100
					on_touch_up: root.slider_adjustment_mean_intensity()
				Label:
					id: label_cell_count_mean_intensity_id
					text: f"{int(slider_cell_count_mean_intensity_id.value[0])}-{int(slider_cell_count_mean_intensity_id.value[1])} %"
					width: '60dp'
					font_size: '12sp'

			# Max Intensity slider
			BoxLayout:
				orientation: 'horizontal'

				Label:
					text: 'Max Intensity'
					tooltip_text: 'Maximum intensity for objects'
					size_hint_x: None
					width: '90dp'
					font_size: '12sp'
				
				RangeSlider:
					id: slider_cell_count_max_intensity_id
					min: 0
					max: 100
					step: 1
					orientation: 'horizontal'
					value1: 0
					value2: 100
					on_touch_up: root.slider_adjustment_max_intensity()
				Label:
					id: label_cell_count_max_intensity_id
					text: f"{int(slider_cell_count_max_intensity_id.value[0])}-{int(slider_cell_count_max_intensity_id.value[1])} %"
					width: '60dp'
					font_size: '12sp'


		# Pad
		Widget:
			size_hint_y: None
			height: '30dp'
			
		RoundedButton:
			text: 'Apply Method to Preview'
			tooltip_text: 'Re-analyze image with new settings'
			size_hint_y: None
			height: '30dp'
			font_size: '12sp'
			on_release: root.apply_method_to_preview_image()

		# Save method
		FileSaveBTN:
			text: 'Save Method As...'
			tooltip_text: 'Store analysis settings in a Method file'
			size_hint_y: None
			height: '30dp'
			font_size: '12sp'
			on_release: self.choose('saveas_cell_count_method')

		
		# Select method to load
		FileChooseBTN:
			text: 'Load Method'
			tooltip_text: 'Retrieve a saved analysis Method'
			size_hint_y: None
			height: '30dp'
			font_size: '12sp'
			on_release: self.choose('load_cell_count_method')

		# Apply method
		FolderChooseBTN:
			text: 'Apply Method to Folder'
			tooltip_text: 'Analyze all images in a folder according to the current Method'
			size_hint_y: None
			height: '30dp'
			font_size: '12sp'
			on_release: self.choose('apply_cell_count_method_to_folder')

		# Empty widget to consume space at bottom of controls panel
		Widget:

	# Image area
	BoxLayout: 
		orientation: 'vertical'
		size_hint_y: 1
		canvas:
			Color:
				rgba: 0,0,0,0
		Image:
			id: cell_count_image_id
			pos_hint: {"x":0.5, "y":0.5}
			source: ""
			canvas:
				Color:
					rgba: 0,0,0,0

	# Empty widget to consume space at bottom of controls panel
	Widget: